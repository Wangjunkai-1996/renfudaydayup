#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
DEPLOY_SCRIPT="${DEPLOY_SCRIPT:-${REPO_ROOT}/scripts/deploy_server.sh}"
DEPLOY_RUNNER="${DEPLOY_RUNNER:-${REPO_ROOT}/scripts/run_deploy_after_push.sh}"
DEPLOY_BRANCH="${DEPLOY_BRANCH:-master}"
DEPLOY_REMOTE="${DEPLOY_REMOTE:-origin}"
HOOK_LOG="${HOOK_LOG:-/tmp/renfu-pre-push.log}"
HOOK_STATE_DIR="${HOOK_STATE_DIR:-/tmp/renfu-pre-push.state.d}"
LATEST_TARGET_FILE="${LATEST_TARGET_FILE:-${HOOK_STATE_DIR}/latest_target}"
DEPLOY_DEBOUNCE_SEC="${DEPLOY_DEBOUNCE_SEC:-8}"
REMOTE_CHECK_TIMEOUT_SEC="${REMOTE_CHECK_TIMEOUT_SEC:-5}"
REMOTE_CHECK_MAX_ATTEMPTS="${REMOTE_CHECK_MAX_ATTEMPTS:-45}"
REMOTE_CHECK_INTERVAL_SEC="${REMOTE_CHECK_INTERVAL_SEC:-1}"

remote_name="${1:-}"
target_ref="refs/heads/${DEPLOY_BRANCH}"
expected_sha=""

ensure_state_dir() {
  mkdir -p "${HOOK_STATE_DIR}"
}

write_latest_target() {
  local sha="$1"
  local tmp_file
  tmp_file="$(mktemp "${HOOK_STATE_DIR}/latest_target.XXXXXX")"
  {
    echo "sha=${sha}"
    echo "remote=${DEPLOY_REMOTE}"
    echo "branch=${DEPLOY_BRANCH}"
    echo "updated_at=$(date '+%F %T')"
  } > "${tmp_file}"
  mv "${tmp_file}" "${LATEST_TARGET_FILE}"
}

while read -r local_ref local_sha remote_ref remote_sha; do
  if [[ "${remote_name}" == "${DEPLOY_REMOTE}" && "${remote_ref}" == "${target_ref}" ]]; then
    expected_sha="${local_sha}"
    break
  fi
done

if [[ -z "${expected_sha}" ]]; then
  exit 0
fi

ensure_state_dir
write_latest_target "${expected_sha}"
touch "${HOOK_LOG}"

if [[ ! -x "${DEPLOY_SCRIPT}" ]]; then
  {
    echo "[$(date '+%F %T')] skip: deploy script not executable: ${DEPLOY_SCRIPT}"
  } >> "${HOOK_LOG}"
  exit 0
fi

if [[ ! -x "${DEPLOY_RUNNER}" ]]; then
  {
    echo "[$(date '+%F %T')] skip: deploy runner not executable: ${DEPLOY_RUNNER}"
  } >> "${HOOK_LOG}"
  exit 0
fi

echo "[renfu] deploy scheduled in background -> ${HOOK_LOG}" >&2

nohup env \
  REPO_ROOT="${REPO_ROOT}" \
  DEPLOY_SCRIPT="${DEPLOY_SCRIPT}" \
  DEPLOY_BRANCH="${DEPLOY_BRANCH}" \
  DEPLOY_REMOTE="${DEPLOY_REMOTE}" \
  HOOK_LOG="${HOOK_LOG}" \
  LATEST_TARGET_FILE="${LATEST_TARGET_FILE}" \
  DEPLOY_DEBOUNCE_SEC="${DEPLOY_DEBOUNCE_SEC}" \
  REMOTE_CHECK_TIMEOUT_SEC="${REMOTE_CHECK_TIMEOUT_SEC}" \
  REMOTE_CHECK_MAX_ATTEMPTS="${REMOTE_CHECK_MAX_ATTEMPTS}" \
  REMOTE_CHECK_INTERVAL_SEC="${REMOTE_CHECK_INTERVAL_SEC}" \
  EXPECTED_SHA="${expected_sha}" \
  "${DEPLOY_RUNNER}" </dev/null >> "${HOOK_LOG}" 2>&1 &

exit 0
